# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# ─── PostgreSQL (internal, managed by docker-compose) ─────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres

# ─── Airflow DB (auto-created by init script) ─────────────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=changeme
AIRFLOW_DB_NAME=airflow_db
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=changeme

# ─── MLflow DB (auto-created by init script) ──────────────────────────────────
MLFLOW_DB_USER=mlflow
MLFLOW_DB_PASSWORD=changeme
MLFLOW_DB_NAME=mlflow_db

# ─── MinIO (S3-compatible object storage for MLflow artifacts) ────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme

# ─── External cms_uaa DB (customer & user accounts) ───────────────────────────
# Required for production scoring. The NIDA you POST to /predict must exist
# as `nin` in user_accounts.
EXTERNAL_DB_HOST=cms-uaa-host.example.com
EXTERNAL_DB_PORT=5432
EXTERNAL_DB_NAME=cms_uaa
EXTERNAL_DB_USER=cms_user
EXTERNAL_DB_PASSWORD=changeme

# ─── External cms_origination DB (loan history, employment, collateral) ───────
ORIGINATION_DB_HOST=cms-origination-host.example.com
ORIGINATION_DB_PORT=5432
ORIGINATION_DB_NAME=cms_origination
ORIGINATION_DB_USER=orig_user
ORIGINATION_DB_PASSWORD=changeme

# ─── Scoring engine flags ─────────────────────────────────────────────────────
# true  (default, production): refuse to score NIDAs missing from cms_uaa
# false (demo): generate deterministic synthetic scores per NIDA
SCORING_STRICT_MODE=true

# ─── API auth ─────────────────────────────────────────────────────────────────
# true  → skip api-key/api-secret enforcement (dev/demo only)
# false → require api-key + api-secret headers on protected endpoints
DISABLE_AUTH=false

# Admin token used to call /auth/clients to issue api-key / api-secret pairs.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Optional hardening (production)
ENFORCE_KEY_EXPIRY=false
REQUIRE_HTTPS=false

# Comma-separated origins for CORS, or "*" for all
ALLOWED_ORIGINS=*

# ─── MLflow tracking + per-model serving URIs (internal docker network) ───────
MLFLOW_TRACKING_URI=http://mlflow-server:5000
MLFLOW_SCORE_MODEL_URI=http://mlflow-server-score:8001
MLFLOW_RISK_MODEL_URI=http://mlflow-server-risk:8002
MLFLOW_LIMIT_MODEL_URI=http://mlflow-server-limit:8003
MLFLOW_FRAUD_MODEL_URI=http://mlflow-server-fraud:8004

# Fraud model resolution
FRAUD_MODEL_NAME=FraudDetector
FRAUD_MODEL_VERSION=1
ENCODER_PATH=/opt/airflow/data/label_encoders.pkl
